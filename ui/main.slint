import { Button, LineEdit, ScrollView } from "std-widgets.slint";

export enum StepStatus {
    not-started,
    in-progress,
    completed,
    failed,
}

component StepIndicator inherits HorizontalLayout {
    in property <StepStatus> status;
    in property <string> label-text;

    spacing: 4px;
    alignment: center;

    Text {
        text: root.status == StepStatus.completed ? "✅"
            : root.status == StepStatus.in-progress ? "⏳"
            : root.status == StepStatus.failed ? "❌"
            : "⚪";
        font-size: 16px;
    }

    Text {
        text: root.label-text;
        color: root.status == StepStatus.completed ? #00c800
             : root.status == StepStatus.in-progress ? #ffa500
             : root.status == StepStatus.failed ? #dc0000
             : #808080;
    }
}

component FolderRow inherits HorizontalLayout {
    in property <string> path;
    callback select();

    spacing: 8px;

    LineEdit {
        text: root.path;
        enabled: false;
        horizontal-stretch: 1;
    }

    Button {
        text: "📁 Select";
        clicked => { root.select(); }
    }
}

export component MainWindow inherits Window {
    title: "AoE2 DE Archiver";
    preferred-width: 700px;
    preferred-height: 600px;
    min-width: 600px;
    min-height: 500px;

    in property <string> source-dir;
    in property <string> out-dir;
    in property <string> disk-space-text;
    in property <bool> disk-space-ok;
    in property <bool> has-progress;
    in property <string> progress-text;
    in property <float> progress-value;
    in property <StepStatus> step1: StepStatus.not-started;
    in property <StepStatus> step2: StepStatus.not-started;
    in property <StepStatus> step3: StepStatus.not-started;
    in property <StepStatus> step4: StepStatus.not-started;
    in property <bool> can-run-all;
    in property <[string]> logs;

    callback select-source-folder();
    callback select-out-folder();
    callback run-all();

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        Text {
            text: "AoE2 DE Archiver";
            font-size: 20px;
            font-weight: 700;
        }

        Rectangle { height: 1px; background: #cccccc; }

        // Progress bar
        if root.has-progress: VerticalLayout {
            spacing: 4px;
            Text { text: root.progress-text; font-size: 12px; }
            Rectangle {
                height: 20px;
                background: #e0e0e0;
                border-radius: 4px;
                clip: true;
                Rectangle {
                    width: parent.width * root.progress-value;
                    height: parent.height;
                    background: #0078d4;
                    x: 0;
                }
            }
        }

        // Disk space
        HorizontalLayout {
            spacing: 4px;
            Text { text: "Disk Space:"; }
            Text {
                text: root.disk-space-text;
                color: root.disk-space-ok ? #00c800 : #dc0000;
            }
        }

        Rectangle { height: 1px; background: #cccccc; }

        Text { text: "Configuration"; font-size: 16px; font-weight: 700; }

        VerticalLayout {
            spacing: 4px;
            Text { text: "AoE2 DE Source Directory"; }
            FolderRow {
                path: root.source-dir;
                select => { root.select-source-folder(); }
            }
        }

        VerticalLayout {
            spacing: 4px;
            Text { text: "Destination Directory"; }
            FolderRow {
                path: root.out-dir;
                select => { root.select-out-folder(); }
            }
        }

        Rectangle { height: 1px; background: #cccccc; }

        Text { text: "Steps"; font-size: 16px; font-weight: 700; }

        HorizontalLayout {
            spacing: 20px;
            StepIndicator { status: root.step1; label-text: "1. Copy"; }
            StepIndicator { status: root.step2; label-text: "2. Goldberg"; }
            StepIndicator { status: root.step3; label-text: "3. Companion"; }
            StepIndicator { status: root.step4; label-text: "4. Launcher"; }
        }

        Button {
            text: "▶ Run All Steps";
            enabled: root.can-run-all;
            clicked => { root.run-all(); }
        }

        Rectangle { height: 1px; background: #cccccc; }

        Text { text: "Logs"; font-size: 16px; font-weight: 700; }

        ScrollView {
            height: 150px;
            viewport-width: self.width;
            VerticalLayout {
                spacing: 2px;
                if root.logs.length == 0: Text {
                    text: "No logs yet";
                    color: #808080;
                }
                for log in root.logs: Text {
                    text: log;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
        }
    }
}
